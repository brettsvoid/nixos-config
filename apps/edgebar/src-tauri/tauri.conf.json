{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "edgebar",
  "version": "0.1.0",
  "identifier": "dev.brett.edgebar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "bar",
        "title": "edgebar-bar",
        "width": 1440,
        "height": 64,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "focusable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
